# Copy this to .env.local and fill in your values

# Vercel KV — get these from Vercel Dashboard → Storage → your KV db → .env.local tab
KV_REST_API_URL=your_kv_url_here
KV_REST_API_TOKEN=your_kv_token_here

# JWT — generate a random 64-char string
JWT_SECRET=change_this_to_a_random_64_char_string_before_deploying

# Super admin bootstrap credentials (used to seed the first login)
SUPER_ADMIN_USER=toros
SUPER_ADMIN_PASS=change_this_to_a_strong_password

# Must match LICENSE_SECRET in the Zyqora desktop server.js
LICENSE_SECRET=Zyq$7mKp9xLv2WnBd5tYs6hJfQe1cR8uAoVz3TGw
